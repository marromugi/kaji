{
  "name": "yunagi",
  "version": "0.1.0",
  "description": "Extract main content from web pages and convert to Markdown",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "yunagi": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "readability",
    "markdown",
    "html",
    "content-extraction",
    "web-scraping"
  ],
  "license": "MIT",
  "author": "marromugi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marromugi/yunagi.git",
    "directory": "packages/yunagi"
  },
  "homepage": "https://github.com/marromugi/yunagi/tree/main/packages/yunagi",
  "bugs": {
    "url": "https://github.com/marromugi/yunagi/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4"
  }
}
